        "    print(\"Atenção: Pontuação inválida para cálculo de bônus.\")\n",
        "\n",
        "# Cálculos\n",
        "valor_bonus = salario * percentual\n",
        "salario_final = salario + valor_bonus\n",
        "\n",
        "# Exibição dos resultados\n",
        "print(\"-\" * 30)\n",
        "print(f\"Valor do Bônus: R$ {valor_bonus:.2f}\")\n",
